# ======================
# Firebase Client SDK
# ======================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ======================
# Firebase Admin SDK
# ======================
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the private key from your service account JSON (include the -----BEGIN/END----- markers)
FIREBASE_ADMIN_PRIVATE_KEY=

# ======================
# Stripe
# ======================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_FOUNDERS_PRICE_ID=

# ======================
# App
# ======================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Bootstrap admin email — only this email is allowed to claim the admin slot
# on first signup. Set this BEFORE deploying so a stranger can't grab admin
# during the deploy window. After admin is claimed, this var is ignored..
BOOTSTRAP_ADMIN_EMAIL=

# ======================
# Cookie Secrets (for next-firebase-auth-edge)
# Generate with: openssl rand -base64 32
# ======================
COOKIE_SECRET_CURRENT=
COOKIE_SECRET_PREVIOUS=

# ======================
# Email (Resend)
# Shared sender — get an API key at https://resend.com and verify your
# sending domain under Domains. EMAIL_FROM must be on a verified domain.
# ======================
RESEND_API_KEY=
EMAIL_FROM="LeadStack <notifications@example.com>"

# ======================
# SMS (Twilio)
# Shared sender — get credentials at https://console.twilio.com. Trial
# accounts can only send to verified numbers and prepend a trial banner.
# ======================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ======================
# Automations / Workflow Recipes (Upstash QStash)
# Get keys at https://console.upstash.com/qstash. The signing keys
# (current + next) verify the inbound POST signature on the step
# executor route; rotate by promoting NEXT to CURRENT.
# QSTASH_URL is the region endpoint shown in the QStash dashboard's
# Quickstart panel — required because the SDK's default doesn't always
# match the token's region.
# Without these, the automation step route returns 503 (graceful fail).
# ======================
QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Server-side secret used to HMAC unsubscribe tokens. Generate with:
# openssl rand -base64 32
# Rotating this value invalidates every outstanding unsubscribe link.
AUTOMATIONS_TOKEN_SECRET=

# ======================
# Website builder (gitpage.site)
# Single agency-level API key, shared by every sub-account. Generate at
# https://www.gitpage.site Dashboard -> API Access -> Generate API Key.
# Format: gp_<64 hex chars>. Rotating regenerates and invalidates the
# previous key.
# GITPAGE_API_URL is optional; defaults to https://www.gitpage.site.
# ======================
GITPAGE_API_KEY=
GITPAGE_API_URL=

# Set to "off" to disable the daily liveness heartbeat to gitpage. The
# heartbeat reports anonymous deployment metadata (instance id, owner
# email, version, sub-account count, builds-last-day, platform) and
# returns whether the agency owner has an active website-builder
# subscription so the UI can show the right CTA. Default: enabled.
# GITPAGE_TELEMETRY=off

# ======================
# AI SMS replies (optional)
# Powers the per-sub-account "AI Replies" feature in Settings. When a
# lead texts a sub-account's dedicated Twilio number, an LLM agent
# replies in real time using the configured persona + safety rails.
#
# Get a key at https://openrouter.ai. One key covers every supported
# model — Anthropic Claude, OpenAI GPT, Google Gemini, etc.
#
# Cost: default model (Claude Haiku 4.5) is ~$0.005-0.02 per SMS
# exchange. Per-sub-account override to Opus 4.7 etc. is ~50x more.
#
# Without these vars, the AI Replies settings panel renders but the
# toggle stays inert — incoming SMS only triggers the existing chat
# thread storage, no AI reply fires.
# ======================
OPENROUTER_API_KEY=

# Default OpenRouter model id when no per-sub-account override is set.
# Leave blank to use Claude Haiku 4.5 (recommended cost/quality balance).
# AI_REPLIES_DEFAULT_MODEL=anthropic/claude-haiku-4-5

# ======================
# Firecrawl (optional — powers the AI Agent website KB)
# When set, the AI Agents -> Overview page exposes a "Refresh KB" button
# that scrapes the sub-account's saved website homepage and stores the
# markdown back on the agent profile. The agent then references it when
# replying to inbound messages.
# Get a key at https://firecrawl.dev -> Dashboard -> API Keys.
# One key per agency deployment — shared across all sub-accounts.
# ======================
FIRECRAWL_API_KEY=

# ======================
# Vapi (optional — powers the AI Voice Agent channel)
# Sign up at https://vapi.ai -> Dashboard -> API Keys for the private
# API key. The webhook secret is anything you generate locally and paste
# into the Vapi assistant's "Server URL Secret" field — Vapi sends it
# back as `Authorization: Bearer <secret>` on every webhook to us so we
# can verify the call came from Vapi and not a stranger who guessed our
# webhook URL. Generate with: openssl rand -base64 32
# Without these the AI Agents -> Voice settings page renders but the
# Enable toggle returns 503 with a friendly "Vapi not configured" error.
# ======================
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=

# ======================
# Meta — Facebook Messenger + Instagram DM inbox (optional, BETA)
# Powers the agency-gated "Facebook + Instagram inbox" beta channels. Create a
# Meta app at https://developers.facebook.com (Business type), add Messenger +
# Instagram, and complete App Review for pages_messaging +
# instagram_manage_messages before it works for non-testers. Register the
# webhook callback (https://YOUR-DOMAIN/api/webhooks/meta) with the verify
# token below, and add https://YOUR-DOMAIN/api/meta/callback as a valid OAuth
# redirect URI — ONE entry for the whole deployment, the same for every
# sub-account (the connecting sub-account is carried in the signed OAuth
# state, so no per-client registration is needed). Without these, the beta
# gate + settings card
# still render but the Connect button reports "not configured on this
# deployment". OAuth `state` is signed with AUTOMATIONS_TOKEN_SECRET (reused).
# ======================
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

# ======================
# Crisp Chat (optional)
# Live-chat widget loaded on every page. Get a Website ID at
# https://app.crisp.chat -> Settings -> Website Settings -> Setup
# Instructions. Leave blank to disable the widget entirely.
# ======================
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# ======================
# Meta Pixel (optional)
# Site-wide Meta (Facebook) Pixel. When set, every page loads the pixel
# and fires PageView automatically; hosted form pages (/f/[id]) also
# fire a `Lead` event on successful submission. Find your Pixel ID at
# Meta Events Manager -> Data Sources. Leave blank to disable.
# ======================
NEXT_PUBLIC_META_PIXEL_ID=

# ======================
# Google Tag Manager (optional)
# Site-wide GTM container. Useful as the escape hatch for any tracking
# tag Meta Pixel doesn't already cover (LinkedIn, TikTok, Hotjar, custom
# server-side events via gtag, etc). Format: GTM-XXXXXXX.
# ======================
NEXT_PUBLIC_GTM_ID=

# ======================
# Leads map (Mapbox)
# Drives the "Where your leads are" map on the sub-account dashboard.
# Free tier: 50,000 map loads / month.
#   1. Sign up at https://account.mapbox.com
#   2. Account -> Tokens -> Create a token (default public scopes are fine)
#   3. Paste the pk.* token below
# Without this, the dashboard renders a "Mapbox not configured" card
# instead of the map — everything else still works.
# ======================
NEXT_PUBLIC_MAPBOX_TOKEN=

# ======================
# Landing-page urgency (LeadStack-variant only — optional)
# Read at build time; changing requires a rebuild/redeploy.
# Leave blank to ship the repo with no urgency UI by default.
#
# NEXT_PUBLIC_FOUNDERS_MANUAL_SOLD — count of founders sales closed
# OUTSIDE Stripe (e.g. Skool community, invoices, manual deals) that the
# Stripe webhook can't see. Added on top of the real Stripe count and
# capped at slotsTotal. Bump this value each time you close an off-Stripe
# sale; Stripe sales accumulate automatically.
# ======================
NEXT_PUBLIC_FOUNDERS_MANUAL_SOLD=

# ======================
# Post-payment GitHub auto-invite (LeadStack-variant only — optional)
# Powers the "Get instant repo access" button on /thank-you. When a
# buyer enters their GitHub username, the server adds them to the
# configured team via the GitHub API — exactly the same path used for
# manual additions today, just automated.
#
# Without these vars: /api/github/invite returns a friendly error and
# buyers fall back to the manual chat path.
#
# Setup:
#   1. Go to https://github.com/settings/tokens?type=beta (fine-grained PAT)
#   2. Resource owner: the org (e.g. Claude-Code-Pro-Camp)
#   3. Repository access: All repositories (or specific repo, doesn't matter for team writes)
#   4. Organization permissions:
#        - Members: Read and write
#   5. Generate token, copy into GITHUB_TOKEN below
#   6. Set GITHUB_INVITE_ORG to the org slug
#   7. Set GITHUB_INVITE_TEAM to the team slug buyers should be added to
#
# Security model: the buyer's claim token (256-bit random, in their
# /thank-you URL only) is hashed with SHA-256 on the server. Only the
# hash is persisted on purchases/{sessionId}. The raw token never
# touches our database.
# ======================
GITHUB_TOKEN=
GITHUB_INVITE_ORG=
GITHUB_INVITE_TEAM=
