rules_version = '2';

// Firebase Storage rules. Writer surfaces: Community group cover/logo
// uploads, and the Client Onboarding page's sub-account branding logo
// upload. Both are PUBLIC reads (Community's About page at /c/* is public;
// branding logos render on public quote/invoice pages) — writes require a
// signed-in Firebase user (staff) plus an image content-type + 5 MB cap.
//
// Deploy with: firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {

    // Community group cover/logo images.
    match /community/{subAccountId}/{groupId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Sub-account branding logo (Client Onboarding page).
    match /branding/{subAccountId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Default deny everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
